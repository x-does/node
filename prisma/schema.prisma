generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model LeadEvent {
  id          BigInt   @id @default(autoincrement())
  eventKey    String   @map("event_key") @db.VarChar(120)
  source      String   @db.VarChar(120)
  userAgent   String?  @map("user_agent") @db.VarChar(255)
  ipHash      String?  @map("ip_hash") @db.VarChar(64)
  automatedUa Boolean  @default(false) @map("automated_ua")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventKey, createdAt])
  @@index([source, createdAt])
  @@index([eventKey, automatedUa, createdAt])
  @@map("openclaw_lead_events")
}

model AppStatus {
  id         Int      @id @default(autoincrement())
  slug       String   @db.VarChar(120)
  title      String   @db.VarChar(255)
  valueText  String   @map("value_text") @db.VarChar(255)
  publicNote String?  @map("public_note") @db.Text
  updatedAt  DateTime @map("updated_at") @db.Timestamp(0)

  @@map("openclaw_app_status")
}

model Product {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(120)
  title       String   @db.VarChar(255)
  description String   @db.Text
  price       Decimal? @db.Decimal(10, 2)
  currency    String   @default("USD") @db.VarChar(3)
  type        String   @db.VarChar(50)
  status      String   @default("active") @db.VarChar(20)
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  ctaUrl      String?  @map("cta_url") @db.VarChar(500)
  ctaLabel    String?  @map("cta_label") @db.VarChar(120)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("openclaw_products")
}

model PageView {
  id        BigInt   @id @default(autoincrement())
  path      String   @db.VarChar(500)
  referrer  String?  @db.VarChar(500)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([path, createdAt])
  @@map("openclaw_page_views")
}

model TrackingEvent {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(120)
  category  String?  @db.VarChar(120)
  payload   Json?
  path      String?  @db.VarChar(500)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@index([category, createdAt])
  @@map("openclaw_tracking_events")
}
