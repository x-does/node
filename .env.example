# Prisma database URL (preferred)
DATABASE_URL=mysql://your_user:your_password@your-db-host.example.com:3306/your_database

# Legacy individual vars (supported as a fallback if DATABASE_URL is missing)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
# DB_SSL=false

# WorkOS AuthKit
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=  # 32+ chars, generate with: openssl rand -base64 32
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
APP_URL=http://localhost:3000
